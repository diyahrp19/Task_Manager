@model IEnumerable<TaskItem>

@{
    ViewData["Title"] = "Task List";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<div class="container mt-4">
    <h2 class="mb-3">Task List</h2>

    <div class="row g-3">
        @foreach (var task in Model)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-end align-items-start mb-2">
                            <a asp-action="Edit"
                               asp-route-id="@task.Id"
                               class="btn btn-outline-primary btn-sm me-2"
                               title="Edit task"
                               aria-label="Edit task">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete"
                               asp-route-id="@task.Id"
                               class="btn btn-outline-danger btn-sm"
                               title="Delete task"
                               aria-label="Delete task">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>

                        <h5 class="card-title mb-2">@task.Title</h5>
                        <p class="card-text text-muted mb-3">@task.Description</p>

                        <div class="mt-auto">
                            <div class="mb-1"><strong>Status:</strong> @task.Status</div>
                            <div class="mb-1"><strong>Priority:</strong> @task.Priority</div>
                            <div><strong>Due Date:</strong> @task.DueDate.ToString("yyyy-MM-dd")</div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
